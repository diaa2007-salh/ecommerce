// prisma/schema.prisma
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"           // swap to "postgresql" for production
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── Catalogue ────────────────────────────────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  comparePrice Float?   // strikethrough price
  stock       Int      @default(0)
  images      String   // JSON array of URLs stored as text
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  total       Float
  shipping    Json        // { name, email, address, city, zip, country }
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Float   // snapshot at time of purchase

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
